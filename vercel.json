{
  "projectType": "python",
  "buildCommand": "pip install -r requirements.txt",
  "cleanUrls": true,
  "env": {
    "PYTHON_VERSION": "3.11"
  },
  "functions": {
    "api/index.py": {
      "runtime": "python3.11"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/static/$1" }
  ]
}
